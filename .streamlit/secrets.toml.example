# Dropbox Configuration (for model storage)
# Get credentials at: https://www.dropbox.com/developers/apps

# Option 1: Long-lived refresh token (RECOMMENDED - never expires)
DROPBOX_APP_KEY = "your_app_key_here"
DROPBOX_APP_SECRET = "your_app_secret_here"
DROPBOX_REFRESH_TOKEN = "your_refresh_token_here"

# Option 2: Short-lived access token (expires after 4 hours)
# DROPBOX_ACCESS_TOKEN = "your_access_token_here"

# GitHub Data Logging (optional)
# GITHUB_TOKEN = "your_github_pat_here"
# GITHUB_REPO = "username/repo"
# GITHUB_BRANCH = "main"

# OpenAI (optional - for LLM features)
# OPENAI_API_KEY = "sk-..."
