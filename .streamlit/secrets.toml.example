# Dropbox Configuration (for model storage)
# Get credentials at: https://www.dropbox.com/developers/apps

# Option 1: Long-lived refresh token (RECOMMENDED - never expires)
DROPBOX_APP_KEY = "your_app_key_here"
DROPBOX_APP_SECRET = "your_app_secret_here"
DROPBOX_REFRESH_TOKEN = "your_refresh_token_here"

# Option 2: Short-lived access token (expires after 4 hours)
# DROPBOX_ACCESS_TOKEN = "your_access_token_here"

# ── Study query set ────────────────────────────────────────────────────────────
# STUDY_SET_DIR, QUERY_SLICE, and STUDY_SET_DROPBOX_FOLDER are hardcoded in
# each app file — do NOT put them in secrets.
#
# For app_study_b77_1..4  (DS system, 100% Banking77 queries):
#   Dataset:  outputs/user_study/study_b77only/  (hardcoded)
#   Slice:    0–3 (hardcoded per app file)
#   Only set:
STUDY_SET = "small"   # small=16 queries | medium=32 | large=48
#
# For app_hicxai_clinc_1..4  (HicXAI system, 100% CLINC150 queries):
#   Dataset:  outputs/user_study/study_clinc150only/  (hardcoded)
#   Dropbox:  /ds_project_queries/study_clinc150only  (hardcoded)
#   Slice:    0–3 (hardcoded per app file)
#   Only set:
# STUDY_SET = "small"   # small=16 queries | medium=32 | large=46
#
# For legacy app_main_study.py / app_main_hicxai.py — set both:
# STUDY_SET_DIR = "outputs/user_study/study_b77only"
# STUDY_SET = "small"
# ──────────────────────────────────────────────────────────────────────────────

# GitHub Data Logging (optional)
# GITHUB_TOKEN = "your_github_pat_here"
# GITHUB_REPO = "username/repo"
# GITHUB_BRANCH = "main"

# OpenAI (optional - for LLM features)
# OPENAI_API_KEY = "sk-..."
