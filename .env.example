# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Model Configuration
EMBEDDING_MODEL=intfloat/e5-base
CLASSIFIER_TYPE=logistic

# Paths (relative to project root)
DATA_DIR=data
CONFIG_DIR=config
OUTPUTS_DIR=outputs
MODELS_DIR=models

# Training Configuration
BATCH_SIZE=64
MAX_ITER=1000
RANDOM_SEED=42

# DS Configuration
MAX_CLARIFICATION_DEPTH=5
RATE_LIMIT_DELAY=1.0
TEMPERATURE=0.01

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# GitHub Data Logging (optional - for centralized user study data storage)
# Using existing private data repository from hicxai-research project
# Generate a Personal Access Token with 'repo' scope at: https://github.com/settings/tokens
GITHUB_DATA_REPO=ksauka/hicxai-data-private
GITHUB_DATA_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dropbox Data Logging (optional - for large file storage)
# Using existing Dropbox app from hicxai-research project
# Ask for app credentials - DO NOT create a new app
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token
