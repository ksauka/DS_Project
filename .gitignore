# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# Model files and checkpoints (but keep trained models for Streamlit)
*.pth
*.h5
*.ckpt
*.pkl
# Allow specific trained models for deployment
!experiments/banking77/banking77_logistic_model.pkl

# Data files (adjust based on your needs)
data/*.csv
data/*.json
data/*.txt
!data/README.md

# Notebook outputs
notebooks/*.csv
notebooks/*.json
notebooks/*.pkl
!notebooks/README.md

# Experiment outputs (generated runs)
experiments/*/*/
experiments/*/*.json
experiments/*/*.csv
!experiments/README.md

# Outputs and logs (but keep selected queries for Streamlit)
outputs/
!outputs/user_study/
!outputs/user_study/workflow_demo/
!outputs/user_study/workflow_demo/selected_queries_for_user_study.csv
logs/
*.log
# Results (but keep optimal thresholds for Streamlit)
results/
!results/banking77/
!results/banking77/workflow_demo/
!results/banking77/workflow_demo/banking77_optimal_thresholds.json
experiments/*/outputs/
experiments/*/results/

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Test artifacts
.pytest_cache/
.tox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Large files
*.csv.gz
*.zip
*.tar.gz
*.rar

# API keys and secrets (extra safety)
**/secrets/
**/credentials/
*.key
*.pem
*.secret

# document files (but keep documentation)
*.docx
*.pdf
*.pptx
*.xlsx
# Allow all markdown documentation
!*.md

